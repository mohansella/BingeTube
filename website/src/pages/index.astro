---
import Layout from "../layout/layout.astro";
import { SiteContants } from "../constants";
import { 
  Github, 
  Play, 
  CheckCircle2, 
  Library, 
  Settings2,
  PlusCircle,
  Zap,
  LayoutList
} from '@lucide/astro';

const appUrl = SiteContants.APP_URL;
const githubUrl = "https://github.com/mohansella/BingeTube";
---

<Layout 
  title="Binge YouTube Videos in Order | BingeTube"
  description="Binge YouTube the right way with BingeTube. Watch videos in order, skip repeats, and finally finish series without getting lost.">

    <section class="relative overflow-hidden">
      <div class="absolute -top-24 left-1/2 -z-10 h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-[#E61819]/10 blur-[120px]"></div>
      
      <div class="mx-auto max-w-7xl px-6 py-28 text-center">
        <div class="mx-auto mb-6 w-fit rounded-full border border-[#E61819]/40 bg-[#E61819]/10 px-4 py-1 text-sm text-white">
          <span class="flex items-center gap-2"><Zap size={14} class="text-[#E61819]" />Finish entire series, not just videos</span>
        </div>

        <h1 class="mx-auto max-w-4xl text-5xl font-bold tracking-tight sm:text-7xl">
          Stop Scrolling.
          <br/>
          <span class="bg-gradient-to-r from-[#E61819] to-[#FF9999] bg-clip-text text-transparent">
            Start finishing.
          </span>
        </h1>

        <h2 class="mx-auto mt-6 max-w-2xl text-xl sm:text-2xl font-medium text-slate-300 leading-relaxed">
          Watch YouTube like a series — in order, without repeats, with real progress tracking.
          <br class="hidden sm:block" />
        </h2>

        <div class="mt-12 flex justify-center gap-6">
          <a href={appUrl} class="flex items-center gap-2 rounded-xl bg-[#E61819] px-8 py-4 font-medium text-white shadow-lg shadow-[#E61819]/20 transition hover:bg-[#FF4444] hover:shadow-xl hover:shadow-[#E61819]/40">
            <Play size={18} fill="currentColor" />
            Start Binging
          </a>
          <a href={githubUrl} target="_blank" class="flex items-center gap-2 rounded-xl border border-slate-700 px-8 py-4 font-medium text-slate-200 transition hover:bg-slate-800">
            <Github size={18} />
            View Source
          </a>
        </div>
      </div>
    </section>

    <section class="border-t border-slate-800 py-24">
      <div class="mx-auto max-w-7xl px-6">
        <div class="grid gap-16 md:grid-cols-2">
          
          <div class="space-y-6">
            <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-[#E61819]/10 text-[#FF4444]">
              <Library size={24} />
            </div>

            <h2 class="text-3xl font-bold tracking-tight">
              Curated series, <br/>ready to binge
            </h2>

            <p class="text-slate-400 text-lg">
              Explore structured collections built from real YouTube channels.  
              Watch videos in order, skip what you've already seen, and finally complete entire YouTube series without getting lost.
            </p>

            <ul class="space-y-3">
              <li class="flex items-center gap-3 text-slate-300">
                <CheckCircle2 size={18} class="text-[#FF4444]" /> Watch videos in the right order
              </li>
              <li class="flex items-center gap-3 text-slate-300">
                <CheckCircle2 size={18} class="text-[#FF4444]" /> Automatically skip repeats
              </li>
              <li class="flex items-center gap-3 text-slate-300">
                <CheckCircle2 size={18} class="text-[#FF4444]" /> Continue exactly where you left off
              </li>
            </ul>
          </div>

          <div class="rounded-3xl border border-slate-800 bg-slate-900/50 p-8 lg:p-12">
            <Settings2 class="mb-6 text-[#FF5555]" size={32} />
            <h3 class="text-2xl font-bold">Create your own series</h3>

            <p class="mt-4 text-slate-400">
              Turn any YouTube channel or playlist into a clean, structured series.  
              Take control of your viewing experience and binge watch YouTube the way you want.
            </p>
            
            <div class="mt-8 space-y-4">
              <div class="flex items-start gap-4 rounded-xl bg-slate-950 p-4 border border-slate-800">
                <PlusCircle class="mt-1 text-[#FF4444]" size={20} />
                <div>
                  <p class="font-medium text-white">Reorder for perfect flow</p>
                  <p class="text-sm text-slate-400">
                    Arrange videos into a logical sequence that actually makes sense.
                  </p>
                </div>
              </div>

              <div class="flex items-start gap-4 rounded-xl bg-slate-950 p-4 border border-slate-800">
                <LayoutList class="mt-1 text-[#FF4444]" size={20} />
                <div>
                  <p class="font-medium text-white">Watch only what matters</p>
                  <p class="text-sm text-slate-400">
                    Pick the best parts of a channel and turn them into a focused binge experience.
                  </p>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <section class="border-t border-slate-800 bg-black py-20">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="text-3xl font-semibold italic text-slate-200">
          "Stop browsing. Start completing."
        </h2>

        <p class="mt-4 text-slate-400 text-lg">
          BingeTube helps you turn endless YouTube scrolling into a structured, satisfying experience — 
          where you actually finish what you start.
        </p>
      </div>
    </section>


    <section class="border-t border-slate-800 py-20">
  <div class="mx-auto max-w-5xl px-6 text-center">

    <h2 class="text-3xl font-bold tracking-tight">
      Start a series
    </h2>

    <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
      Explore curated YouTube channels organized like series. Watch in order, skip repeats, and track your progress.
    </p>

    <div class="mt-8 flex justify-center">
      <a href="/series" class="rounded-xl bg-[#E61819] px-8 py-4 font-medium text-white shadow-lg shadow-[#E61819]/20 transition hover:bg-[#FF4444]">
        Browse all series
      </a>
    </div>

    <div class="mt-10 flex flex-wrap justify-center gap-4 text-sm text-slate-400">
      <a href="/series/comedy/key_and_peele" class="hover:text-[#FF4444]">Key & Peele</a>
      <a href="/series/science/veritasium" class="hover:text-[#FF4444]">Veritasium</a>
      <a href="/series/science/kurzgesagt" class="hover:text-[#FF4444]">Kurzgesagt</a>
    </div>

  </div>
</section>

    <p class="sr-only">
      BingeTube lets you binge watch YouTube videos in order, skip already watched videos,
      and track your progress across playlists and channels without repeats.
    </p>

</Layout>
