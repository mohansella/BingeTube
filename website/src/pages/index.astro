---
import Layout from "../layout/layout.astro";
import { SiteContants } from "../constants";
import { 
  Github, 
  Play, 
  CheckCircle2, 
  Library, 
  Settings2,
  PlusCircle,
  Zap,
  LayoutList
} from '@lucide/astro';

import discover from "../../public/discover/discover.json";
const topPicks = discover.top_picks.slice(0, 10).map((id) => discover.models[`${id}.binge` as keyof typeof discover.models]);

const appUrl = SiteContants.APP_URL;
const githubUrl = "https://github.com/mohansella/BingeTube";
---

<Layout 
  title="Binge YouTube Videos in Order | BingeTube"
  description="Binge YouTube the right way with BingeTube. Watch videos in order, skip repeats, and finally finish series without getting lost.">

    <section class="relative overflow-hidden">
      <div class="absolute inset-0 perspective" style="perspective: 1200px;">
        <img
          src="/discover/poster.jpg"
          alt="BingeTube series poster"
          class="h-full w-full object-cover opacity-40"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/30 to-black/50"></div>
      </div>

      
      <div class="relative z-10 mx-auto max-w-7xl px-6 py-16 sm:py-28 text-center">
        <div class="mx-auto mb-6 w-fit rounded-full border border-[#E61819]/40 bg-[#E61819]/10 px-4 py-1 text-sm text-white backdrop-blur-sm">
          <span class="flex items-center gap-2"><Zap size={14} class="text-[#E61819]" />Finish entire series, not just videos</span>
        </div>

        <h1 class="mx-auto max-w-4xl text-4xl font-bold leading-tight tracking-tight sm:text-5xl md:text-7xl">
          Watch YouTube Series
          <br/>
          <span class="bg-gradient-to-r from-[#E61819] to-[#FF9999] bg-clip-text text-transparent">
            in Perfect Order.
          </span>
        </h1>

        <h2 class="mx-auto mt-6 max-w-2xl text-xl sm:text-2xl font-medium text-slate-300 leading-relaxed">
          Escape the endless algorithmic feed. Turn your favorite channels into TV seasons with zero repeats and zero distractions.
          <br class="hidden sm:block" />
        </h2>

        <div class="mt-10 flex flex-col sm:flex-row justify-center gap-3 sm:gap-6 px-2 sm:px-0">
          <a href={appUrl} class="flex items-center justify-center gap-2 rounded-xl bg-[#E61819] px-6 sm:px-8 py-4 font-medium text-white shadow-lg shadow-[#E61819]/20 transition hover:bg-[#FF4444] hover:shadow-xl hover:shadow-[#E61819]/40 w-full sm:w-auto">
            <Play size={18} fill="currentColor" />
            Open BingeTube App
          </a>
          <a href={githubUrl} target="_blank" class="flex items-center justify-center gap-2 rounded-xl border border-slate-700 bg-slate-900/50 backdrop-blur-sm px-6 sm:px-8 py-4 font-medium text-slate-200 transition hover:bg-slate-800 w-full sm:w-auto">
            <Github size={18} />
            View Source
          </a>
        </div>
      </div>
    </section>

    <section class="relative z-20 pt-2 pb-16">
      <div class="mx-auto max-w-7xl">
        
        <h2 class="mb-6 px-6 text-2xl font-semibold text-white">
          Top Picks
        </h2>

        <div class="flex gap-5 overflow-x-auto py-6 px-6 scrollbar-hide after:content-[''] after:w-1 after:shrink-0">
          {topPicks.map((item, i) => (
            <div class="relative ml-4 min-w-[260px] sm:min-w-[280px] md:min-w-[320px] lg:min-w-[360px] hover:z-50">
              
              {/* Background Number */}
              <span
                class="absolute -left-2 sm:-left-6 bottom-2 text-[80px] sm:text-[110px] font-extrabold text-white/20 z-10 leading-none pointer-events-none"
                style="-webkit-text-stroke: 2px rgba(255,255,255,0.4);"
              >
                {i + 1}
              </span>

              {/* Card Container */}
              <div class="relative ml-4 z-20 overflow-hidden rounded-xl shadow-lg transition duration-300 hover:scale-105">
                <div class="relative aspect-video w-full">
                  {/* Cover Image */}
                  <img src={item.coverUrl} alt={item.title} class="h-full w-full object-cover scale-[1.05]" />
                  
                  {/* Gradient Overlay for Text Legibility */}
                  <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent pointer-events-none"></div>

                  {/* Bottom Left Content (Icon & Title) */}
                  <div class="absolute bottom-0 left-0 w-full p-3 flex items-center gap-2.5 pointer-events-none">
                    <img src={item.iconUrl} alt="Icon" class="w-6 h-6 rounded-full border border-white/20 shadow-sm shrink-0 object-cover bg-slate-800" />
                    
                    <div class="flex min-w-0 items-center">
                      <span class="text-white text-sm sm:text-base font-bold truncate drop-shadow-md">
                        {item.title}
                      </span>
                    </div>
                  </div>
                  
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-slate-800 py-12 md:py-24">
      <div class="mx-auto max-w-7xl px-6">
        <div class="grid gap-10 md:gap-16 md:grid-cols-2">
          
          <div class="space-y-6">
            <div class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-[#E61819]/10 text-[#FF4444]">
              <Library size={24} />
            </div>

            <h2 class="text-3xl font-bold tracking-tight">
              Curated series, <br/>ready to binge
            </h2>

            <p class="text-slate-400 text-lg">
              Stop letting recommendations dictate your curiosity. Explore structured collections built from real YouTube channels. Watch uninterrupted, automatically skip what you've already seen, and finally complete entire storylines without getting lost.
            </p>

            <ul class="space-y-4">
              <li class="flex items-start sm:items-center gap-3 text-slate-300">
                <CheckCircle2 size={22} class="text-[#FF4444] shrink-0 mt-0.5 sm:mt-0" /> Watch videos in the right order
              </li>
              <li class="flex items-start sm:items-center gap-3 text-slate-300">
                <CheckCircle2 size={22} class="text-[#FF4444] shrink-0 mt-0.5 sm:mt-0" /> Automatically skip repeats
              </li>
              <li class="flex items-start sm:items-center gap-3 text-slate-300">
                <CheckCircle2 size={22} class="text-[#FF4444] shrink-0 mt-0.5 sm:mt-0" /> Continue exactly where you left off
              </li>
            </ul>
          </div>

          <div class="rounded-3xl border border-slate-800 bg-slate-900/50 p-6 sm:p-8 lg:p-12">
            <Settings2 class="mb-6 text-[#FF5555]" size={32} />
            <h3 class="text-2xl font-bold">Create your own series</h3>

            <p class="mt-4 text-slate-400">
              Turn any chaotic YouTube channel or playlist into a clean, TV-style season.  
              Take back control of your screen time and binge watch exactly what you want, distraction-free.
            </p>
            
            <div class="mt-8 space-y-4">
              <div class="flex items-start gap-4 rounded-xl bg-slate-950 p-4 border border-slate-800">
                <PlusCircle class="mt-1 text-[#FF4444]" size={20} />
                <div>
                  <p class="font-medium text-white">Reorder for perfect flow</p>
                  <p class="text-sm text-slate-400">
                    Arrange videos into a logical sequence that actually makes sense.
                  </p>
                </div>
              </div>

              <div class="flex items-start gap-4 rounded-xl bg-slate-950 p-4 border border-slate-800">
                <LayoutList class="mt-1 text-[#FF4444]" size={20} />
                <div>
                  <p class="font-medium text-white">Watch only what matters</p>
                  <p class="text-sm text-slate-400">
                    Pick the best parts of a channel and turn them into a focused binge experience.
                  </p>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <section class="border-t border-slate-800 bg-black py-12 md:py-20">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="text-2xl md:text-3xl font-semibold italic text-slate-200">
          "Stop browsing. Start completing."
        </h2>

        <p class="mt-4 text-slate-400 text-lg">
          BingeTube helps you turn the chaotic, distracting algorithmic feed into a structured, cinematic experience — 
          where you actually finish what you start.
        </p>
      </div>
    </section>


    <section class="border-t border-slate-800 py-12 md:py-20">
  <div class="mx-auto max-w-5xl px-6 text-center">

    <h2 class="text-3xl font-bold tracking-tight">
      Start a series
    </h2>

    <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
      Escape the endless scroll. Browse our curated directories to watch your favorite YouTube channels in perfect sequential order without interruptions.
    </p>

    <div class="mt-8 flex justify-center px-4 sm:px-0">
      <a href="/series" class="flex items-center justify-center rounded-xl bg-[#E61819] px-8 py-4 font-medium text-white shadow-lg shadow-[#E61819]/20 transition hover:bg-[#FF4444] w-full sm:w-auto">
        Browse all series
      </a>
    </div>

  </div>
</section>

    <p class="sr-only">
      BingeTube lets you binge watch YouTube videos in order, skip already watched videos,
      and track your progress across playlists and channels without repeats.
    </p>

</Layout>
